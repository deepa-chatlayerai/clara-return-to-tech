generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?   // null for OAuth users
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile       UserProfile?
  accounts      Account[]
  sessions      Session[]
  applications  JobApplication[]
  cvs           CV[]
  userCourses   UserCourse[]
  practiceSessions PracticeSession[]
  streak        Streak?
  wins          Win[]
  communityProfile CommunityProfile?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── USER PROFILE ────────────────────────────────────────────────────────────

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  targetRole        String?
  currentLocation   String?
  countryOfOrigin   String?
  careerGapYears    Int?
  careerGapReason   String?  // "family", "relocation", "health", "other"
  skills            String[] // array of skill strings
  experienceYears   Int?
  bio               String?
  linkedinUrl       String?
  targetSalaryMin   Int?
  targetSalaryMax   Int?
  preferredWorkType String?  // "remote", "hybrid", "onsite"
  onboardingDone    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── JOB APPLICATIONS ────────────────────────────────────────────────────────

model JobApplication {
  id          String            @id @default(cuid())
  userId      String
  jobTitle    String
  company     String
  location    String?
  jobUrl      String?
  salary      String?
  status      ApplicationStatus @default(SAVED)
  matchScore  Int?
  notes       String?
  appliedAt   DateTime?
  interviewAt DateTime?
  cvId        String?           // which CV version was used
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  CLOSED
}

// ─── CVS ─────────────────────────────────────────────────────────────────────

model CV {
  id           String   @id @default(cuid())
  userId       String
  name         String   // e.g. "General Tech", "Proximus Tailored"
  content      String   // JSON stringified CV data
  fileUrl      String?  // S3 URL for PDF
  tailoredFor  String?  // job title it was tailored for
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cvs")
}

// ─── COURSES ─────────────────────────────────────────────────────────────────

model Course {
  id          String       @id @default(cuid())
  title       String
  platform    String       // "Udemy", "Coursera", "LinkedIn", "YouTube", "Free"
  url         String
  instructor  String?
  durationHrs Float?
  level       String?      // "Beginner", "Intermediate", "Advanced"
  skillTags   String[]
  rating      Float?
  price       String?      // "Free", "€14.99", etc.
  isFree      Boolean      @default(false)
  createdAt   DateTime     @default(now())

  userCourses UserCourse[]

  @@map("courses")
}

model UserCourse {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  progressPct Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  notes       String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("user_courses")
}

// ─── PRACTICE ────────────────────────────────────────────────────────────────

model PracticeSession {
  id          String       @id @default(cuid())
  userId      String
  type        PracticeType
  topic       String?
  score       Int?         // percentage 0-100
  durationMin Int?
  completedAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("practice_sessions")
}

enum PracticeType {
  QUIZ
  JOB_READINESS
  HANG_OUT
  PUZZLE
}

// ─── STREAKS ─────────────────────────────────────────────────────────────────

model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model CommunityProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String
  location      String?
  bio           String?
  isVisible     Boolean  @default(true)
  lookingFor    String[] // "study-buddy", "coffee-chat", "mentor", "mentee"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  wins Win[]

  @@map("community_profiles")
}

model Win {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  message   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("wins")
}
